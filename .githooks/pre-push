#!/usr/bin/env bash
# Pre-push hook — valida nombre de rama y bloquea push directo a ramas protegidas.
# Instalación: git config core.hooksPath .githooks
set -euo pipefail

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
PROTECTED_BRANCHES="develop qa main"
HU_PATTERN='^HU-[A-Z0-9]'

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

# Bloquear push directo a ramas protegidas
for protected in $PROTECTED_BRANCHES; do
  if [ "$CURRENT_BRANCH" = "$protected" ]; then
    echo ""
    echo -e "${RED}╔══════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║         PUSH DIRECTO BLOQUEADO                       ║${NC}"
    echo -e "${RED}╚══════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "  Rama actual : ${RED}${CURRENT_BRANCH}${NC}"
    echo ""
    echo -e "  No se permite push directo a ramas protegidas."
    echo -e "  Usa el flujo de Pull Request:"
    echo ""
    echo -e "    ${GREEN}HU-* → develop → qa → main${NC}"
    echo ""
    exit 1
  fi
done

# Advertir si el nombre de rama no sigue la convención HU-*
if ! echo "$CURRENT_BRANCH" | grep -qE "$HU_PATTERN"; then
  echo ""
  echo -e "${YELLOW}╔══════════════════════════════════════════════════════╗${NC}"
  echo -e "${YELLOW}║         ADVERTENCIA: nombre de rama no convencional  ║${NC}"
  echo -e "${YELLOW}╚══════════════════════════════════════════════════════╝${NC}"
  echo ""
  echo -e "  Rama actual : ${YELLOW}${CURRENT_BRANCH}${NC}"
  echo -e "  Formato esperado: ${GREEN}HU-{AMBIENTE}-{INICIALES}-{Descripcion}${NC}"
  echo -e "  Ejemplo:          ${GREEN}HU-DEV-JSA-01-mi-feature${NC}"
  echo ""
  echo -e "  El push continuará, pero el PR a ${YELLOW}develop${NC} será rechazado"
  echo -e "  por el workflow de validación en GitHub Actions."
  echo ""
fi

echo -e "${GREEN}✅ Pre-push: validación completada — ${CURRENT_BRANCH}${NC}"
exit 0
